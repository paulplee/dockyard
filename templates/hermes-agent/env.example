# Secrets — mounted read-only at /secrets inside the container.
#
# Copy this file to 'env' and fill in your values:
#
#   cp /secrets/env.example /secrets/env
#
# Then source it on login by adding to ~/.bashrc:
#
#   [ -f /secrets/env ] && set -a && source /secrets/env && set +a
#
# IMPORTANT: never commit this file with real credentials.

# LLM APIs (required by Hermes Agent)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://...

# LiteLLM proxy (pre-configured in docker-compose.yml)
# LITELLM_BASE_URL=http://host.gateway.internal:4000

# Hermes Agent configuration
# HERMES_MODEL=openai/gpt-4o
# HERMES_MODE=autonomous  # autonomous | assistant | interactive

# Version control
# GITHUB_TOKEN=ghp_...
# GITLAB_TOKEN=glpat-...

# Cloud providers
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=ap-east-1
