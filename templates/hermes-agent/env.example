# Secrets — mounted read-only at /secrets inside the container.
#
# Copy this file to 'env' and fill in your values:
#
#   cp /secrets/env.example /secrets/env
#
# Then source it on login by adding to ~/.bashrc:
#
#   [ -f /secrets/env ] && set -a && source /secrets/env && set +a
#
# IMPORTANT: never commit this file with real credentials.

# LLM APIs (required by Hermes Agent)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://...

# LiteLLM proxy (pre-configured in docker-compose.yml)
# LITELLM_BASE_URL=http://host.gateway.internal:4000

# API Server — built-in OpenAI-compatible endpoint for external clients
# Uncomment and set API_SERVER_KEY to a secure random string (at least 32 chars).
# Keep API_SERVER_ENABLED=true unless you want to disable external API access.
# API_SERVER_ENABLED=true
# API_SERVER_KEY=your-secret-api-key-here
# API_SERVER_HOST=0.0.0.0   # set to 127.0.0.1 to restrict to localhost-only
# API_SERVER_CORS_ORIGINS=*  # allow all origins; set to specific URLs for tighter control

# Hermes Agent configuration
# HERMES_MODEL=openai/gpt-4o
# HERMES_MODE=autonomous  # autonomous | assistant | interactive

# Version control
# GITHUB_TOKEN=ghp_...
# GITLAB_TOKEN=glpat-...
#
# Git commit identity — used by container-init.sh to set git user.name/email
# (written to ~/.config/git/config which persists across restarts)
# GIT_AUTHOR_NAME=Hermes Agent
# GIT_AUTHOR_EMAIL=hermes@example.com

# Cloud providers
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=ap-east-1
