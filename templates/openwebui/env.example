# Secrets — mounted read-only at /secrets inside the container.
#
# Copy this file to 'env' and fill in your values:
#
#   cp /secrets/env.example /secrets/env
#
# Then source it on login by adding to ~/.bashrc:
#
#   [ -f /secrets/env ] && set -a && source /secrets/env && set +a
#
# IMPORTANT: never commit this file with real credentials.

# Hermes Agent API key — must match API_SERVER_KEY in your hermes-agent deployment.
# Generate a secure random key: openssl rand -hex 32
OPENAI_API_KEY=your-hermes-api-key-here

# Open WebUI session secret — used to sign user session tokens.
# Generate a secure random key: openssl rand -hex 32
WEBUI_SECRET_KEY=your-webui-secret-key-here

# Disable authentication (not recommended for internet-facing deployments)
# WEBUI_AUTH=false

# Override the Hermes API URL if it differs from the default set at deploy time
# HERMES_API_URL=http://host.gateway.internal:8642/v1
