# Secrets — mounted read-only at /secrets inside the container.
#
# Copy this file to 'env' and fill in your values:
#
#   cp /secrets/env.example /secrets/env
#
# Then source it on login by adding to ~/.bashrc:
#
#   [ -f /secrets/env ] && set -a && source /secrets/env && set +a
#
# IMPORTANT: never commit this file with real credentials.

# LLM APIs
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# Version control
# GITHUB_TOKEN=ghp_...
# GITLAB_TOKEN=glpat-...
#
# Git commit identity — used by entrypoint.sh to set git user.name/email
# (written to ~/.config/git/config which persists across restarts)
# GIT_AUTHOR_NAME=Dev User
# GIT_AUTHOR_EMAIL=dev@example.com

# Cloud providers
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=ap-east-1
