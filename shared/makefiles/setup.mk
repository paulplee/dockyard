# =============================================================================
# dockyard — shared Makefile: setup
# Included by each template's Makefile.
# Provides: make setup (interactive .env generator)
# =============================================================================

# .env is written to VOLUMES_BASE (outside the repo, in the deployment path).
# Variables:  CONTAINER_NAME, AGENT_UID, AGENT_GID, SSH_PORT

.PHONY: setup

setup:
	@echo "=== Dockyard Deployment Setup ==="
	@echo ""
	@hostcfg="$(HOME)/.config/dockyard/.env"; \
	 mkdir -p "$(HOME)/.config/dockyard"; \
	 if [ -f "$$hostcfg" ]; then . "$$hostcfg"; fi; \
	 if [ -z "$${VOLUMES_ROOT:-}" ]; then \
	   defvol="$(HOME)/.config/dockyard/volumes"; \
	   read -p "Volumes root path [$$defvol]: " VOLUMES_ROOT; \
	   VOLUMES_ROOT="$${VOLUMES_ROOT:-$$defvol}"; \
	   printf "VOLUMES_ROOT=$$VOLUMES_ROOT\n" > "$$hostcfg"; \
	   echo "  Written VOLUMES_ROOT to $$hostcfg"; \
	 else \
	   echo "  Volumes root: $$VOLUMES_ROOT  (from $$hostcfg)"; \
	 fi; \
	 echo ""; \
	 read -p "Deployment name              : " name; \
	 defuid=1100; \
	 while getent passwd "$$defuid" >/dev/null 2>&1; do defuid=$$((defuid + 1)); done; \
	 read -p "Agent UID                [$$defuid]: " uid; \
	 uid="$${uid:-$$defuid}"; \
	 defport=2200; \
	 while ss -tlnH 2>/dev/null | awk '{print $$4}' | grep -q ":$$defport$$"; do defport=$$((defport + 1)); done; \
	 read -p "SSH port on host         [$$defport]: " port; \
	 port="$${port:-$$defport}"; \
	 echo ""; \
	 echo "Node.js version options:"; \
	 echo "  24 — Current (default, recommended by OpenClaw)"; \
	 echo "  22 — LTS (use on older CPUs: Westmere / Sandy Bridge era)"; \
	 read -p "Node.js major version       [24]: " node_major; \
	 node_major="$${node_major:-24}"; \
	 while [ "$$node_major" != "22" ] && [ "$$node_major" != "24" ]; do \
	   read -p "  Invalid — enter 22 or 24   [24]: " node_major; \
	   node_major="$${node_major:-24}"; \
	 done; \
	 envdir="$$VOLUMES_ROOT/$$name"; \
	 sudo mkdir -p "$$envdir"; \
	 envfile="$$envdir/.env"; \
	 if [ -f "$$envfile" ]; then \
	   sudo sed -i '/^CONTAINER_NAME=/d;/^AGENT_UID=/d;/^AGENT_GID=/d;/^SSH_PORT=/d;/^NODE_MAJOR=/d;/^# Deployment parameters/d' "$$envfile"; \
	 fi; \
	 printf "# Deployment parameters (generated by 'make setup')\nCONTAINER_NAME=$$name\nAGENT_UID=$$uid\nAGENT_GID=$$uid\nSSH_PORT=$$port\nNODE_MAJOR=$$node_major\n" | sudo tee -a "$$envfile" > /dev/null; \
	 echo ""; \
	 keyfile=""; \
	 sshdir="$$envdir/ssh"; \
	 sudo mkdir -p "$$sshdir"; \
	 akfile="$$sshdir/authorized_keys"; \
	 if [ ! -f "$$akfile" ] || [ ! -s "$$akfile" ]; then \
	   pubkeys=$$(ls $(HOME)/.ssh/*.pub 2>/dev/null); \
	   if [ -n "$$pubkeys" ]; then \
	     echo "Available SSH public keys:"; \
	     i=1; \
	     for k in $$pubkeys; do echo "  $$i) $$k"; i=$$((i + 1)); done; \
	     defkey=$$(echo "$$pubkeys" | head -1); \
	     read -p "SSH public key to authorize [$$defkey]: " chosen; \
	     chosen="$${chosen:-$$defkey}"; \
	     if echo "$$chosen" | grep -qE '^[0-9]+$$'; then \
	       chosen=$$(echo "$$pubkeys" | sed -n "$${chosen}p"); \
	     fi; \
	     sudo cp "$$chosen" "$$akfile"; \
	     sudo chmod 600 "$$akfile"; \
	     keyfile="$${chosen%.pub}"; \
	     echo "  Installed $$(basename $$chosen) into $$akfile"; \
	   else \
	     echo "  WARNING: No SSH public keys found in $(HOME)/.ssh/"; \
	     echo "  You will need to manually place an authorized_keys file at:"; \
	     echo "    $$akfile"; \
	   fi; \
	 else \
	   echo "  SSH authorized_keys already exists at $$akfile — skipping"; \
	 fi; \
	 [ -z "$$keyfile" ] && keyfile=$$(ls $(HOME)/.ssh/*.pub 2>/dev/null | head -1 | sed 's/\.pub$$//'); \
	 [ -z "$$keyfile" ] && keyfile="$(HOME)/.ssh/id_ed25519"; \
	 sshcfg="$(HOME)/.ssh/config"; \
	 stanza="# dockyard: dy-$$name"; \
	 if ! grep -qF "$$stanza" "$$sshcfg" 2>/dev/null; then \
	   printf "\n$$stanza\nHost dy-$$name\n    HostName 127.0.0.1\n    Port $$port\n    User agent\n    IdentityFile $$keyfile\n    IdentitiesOnly yes\n    StrictHostKeyChecking accept-new\n    UserKnownHostsFile $(HOME)/.config/dockyard/known_hosts\n" >> "$$sshcfg"; \
	   chmod 600 "$$sshcfg"; \
	   echo "  Added 'dy-$$name' to ~/.ssh/config  →  ssh dy-$$name"; \
	 else \
	   echo "  SSH config entry 'dy-$$name' already exists — skipping"; \
	 fi; \
	 echo ""; \
	 echo "Written to $$envfile:"; \
	 cat "$$envfile"; \
	 echo ""; \
	 echo "Next: make deploy c=$$name   then   ssh dy-$$name"
